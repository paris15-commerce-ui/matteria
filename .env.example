# ============================================================
# MatterGuide AI — Variables d'environnement
# Copier ce fichier en .env.local pour le dev local
# Sur Netlify : Site > Environment variables > Add a variable
# ============================================================

# ----- App -----
NEXT_PUBLIC_APP_URL=https://matterguide.netlify.app

# ----- Supabase -----
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ----- Groq (https://console.groq.com → API Keys) -----
# FREE TIER : 14 400 req/jour, 30 req/min — suffisant pour les démos
GROQ_API_KEY=gsk_...
# Modèle par défaut (ne pas changer sauf besoin)
GROQ_MODEL=llama-3.3-70b-versatile

# ----- Matterport -----
NEXT_PUBLIC_MATTERPORT_SDK_KEY=xxxxxxxxxxxxxxxxxxxxxxxx

# ----- Stripe (désactivé — commenter jusqu'à activation) -----
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_AGENCE=price_...

# ----- OpenAI (désactivé — remplacé par Groq) -----
# OPENAI_API_KEY=sk-...
# OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
# OPENAI_REALTIME_VOICE=verse
